# Exemplo de variáveis de ambiente para conectar o Prisma ao Supabase
# Substitua os valores abaixo pela connection string do seu projeto Supabase
# Exemplo de connection string (Supabase):
# postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require

DATABASE_URL="postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>?sslmode=require"
# DIRECT_URL pode ser usado pelo Prisma para conexões diretas (opcional)
DIRECT_URL="postgresql://<USER>:<PASSWORD>@<HOST>:<PORT>/<DATABASE>?sslmode=require"

# JWT secret usado pela API (mantenha em segredo)
JWT_SECRET="sua_chave_jwt_super_secreta"

# URL do projeto Supabase (ex: https://xyzabc.supabase.co)
SUPABASE_URL="https://<project>.supabase.co"

DATABASE_URL="postgresql://seu_usuario:sua_senha@localhost:5432/readex_db"
DIRECT_URL="postgresql://seu_usuario:sua_senha@localhost:5432/readex_db"


NODE_ENV="development"
